<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh Sách Người Dùng</title>
    <!-- Nhúng CSS Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Quản lý người dùng</h2>
            <a href="/crud" class="btn btn-success">+ Thêm người dùng mới</a>
        </div>
        
        <div class="table-responsive shadow">
            <table class="table table-bordered table-striped table-hover mb-0 text-center">
                <thead class="thead-dark">
                    <tr>
                        <th>Email</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Address</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let i=0; i < datalist.length; i++) { %>
                        <tr>
                            <td class="align-middle"><%= datalist[i].email %></td>
                            <td class="align-middle"><%= datalist[i].firstName %></td>
                            <td class="align-middle"><%= datalist[i].lastName %></td>
                            <td class="align-middle"><%= datalist[i].address %></td>
                            <td class="align-middle">
                                <a href="/edit-crud?id=<%= datalist[i].id %>" class="btn btn-warning btn-sm">Sửa</a>
                                <a href="/delete-crud?id=<%= datalist[i].id %>" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa user này?')">Xóa</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>